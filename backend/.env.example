# ----- Server -----
PORT=8100

# ----- Access gate (abuse / credit-drain protection) -----
# When set, all data endpoints require an "X-Access-Token" header with this value.
# Leave empty for an open local dev API.
# ACCESS_TOKEN=obrio-2026

# ----- LLM: OpenRouter (free tier) — used from phase 3 -----
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ----- Optional paid escalation at runtime / distillation teacher (dev-time) -----
# OPENAI_API_KEY=

# ----- Langfuse (optional LLM tracing) -----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
